# 复制为 .env 后按需修改：cp .env.example .env

# 前端访问端口（浏览器打开 http://localhost:8080）
FRONTEND_PORT=8080
BACKEND_PORT=8000
MYSQL_PORT=3306

# MySQL
MYSQL_ROOT_PASSWORD=ims_root_pass
MYSQL_USER=ims
MYSQL_PASSWORD=ims_pass
MYSQL_DB=ims

# 后端
APP_NAME=IMS
DEBUG=false
JWT_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# 首次启动自动创建的管理员（已存在则跳过）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NICKNAME=管理员
