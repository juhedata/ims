APP_NAME=IMS

DEBUG=True

# 服务监听端口，不配置默认 8000
PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=ims

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 启动时是否自动执行 alembic 迁移（开发环境可设 true）
AUTO_MIGRATE=false

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 跨域白名单，多个地址用逗号分隔
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:3000

# 上传文件目录（Logo 等），相对路径基于 backend 工作目录
UPLOAD_DIR=uploads
UPLOAD_URL_PREFIX=/uploads
MAX_LOGO_SIZE=2097152
